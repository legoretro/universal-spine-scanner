# Do not put real values in GitHub.
# Add real values in local .env or in your hosting environment variables.

PORT=4174

# Same Supabase project you already created.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_hosting_secret_only
SUPABASE_SCANS_TABLE=spine_scans
SUPABASE_SOLD_MEMORY_TABLE=resale_sold_memory

# eBay Production API keys for real-time lookup.
EBAY_CLIENT_ID=replace_with_ebay_app_id
EBAY_CLIENT_SECRET=replace_with_ebay_cert_id
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CURRENCY=USD

# Optional stronger scanner.
# Leave blank to use the free OCR fallback only.
OPENAI_API_KEY=replace_with_openai_api_key_if_you_choose
OPENAI_VISION_MODEL=gpt-4.1-mini

# Allow the GitHub Pages scanner to call this backend.
ALLOWED_ORIGINS=https://legoretro.github.io
